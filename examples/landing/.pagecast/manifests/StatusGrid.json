{
  "name": "StatusGrid",
  "import": "./components/StatusGrid.tsx",
  "description": "List of labeled items with ready/blocked/warning status tags.",
  "propsSchema": {
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["label", "status"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "status": { "enum": ["ready", "blocked", "warning"] }
          }
        }
      }
    }
  }
}
