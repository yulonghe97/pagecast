{
  "name": "Features",
  "import": "./components/Features.tsx",
  "description": "N-up grid of feature cards: bold title + short body. No mono eyebrows.",
  "propsSchema": {
    "type": "object",
    "required": ["title", "items"],
    "additionalProperties": false,
    "properties": {
      "eyebrow": { "type": "string" },
      "title": { "type": "string", "minLength": 1 },
      "sub": { "type": "string" },
      "items": {
        "type": "array",
        "minItems": 1,
        "maxItems": 8,
        "items": {
          "type": "object",
          "required": ["title", "body"],
          "additionalProperties": false,
          "properties": {
            "logo": {
              "type": "string",
              "enum": ["json-schema", "react", "esbuild", "html5"]
            },
            "title": { "type": "string", "minLength": 1 },
            "body": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
